# Telegram Bot (isi jika ingin notifikasi Telegram)
# Cara dapat token: chat dengan @BotFather di Telegram
# Cara dapat chat_id: chat dengan @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook (isi jika ingin notifikasi Discord)
# Cara dapat: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=
